{
  "name": "dcgoodwin2112/dkan_nl_query",
  "description": "Natural language query interface for DKAN.",
  "type": "drupal-custom-module",
  "license": "GPL-2.0-or-later",
  "require": {},
  "require-dev": {
    "drupal/core": "^10.2 || ^11",
    "phpunit/phpunit": "^9 || ^10"
  },
  "autoload": {
    "psr-4": {
      "Drupal\\dkan_nl_query\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Drupal\\Tests\\dkan_nl_query\\": "tests/src/",
      "Drupal\\dkan_query_tools\\": "../dkan_query_tools/src/"
    }
  },
  "config": {
    "allow-plugins": {
      "drupal/core-composer-scaffold": false
    }
  }
}
